{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "strict": true,
        "paths": {
            "@/types": ["../shared/types.d.ts"]
        }
    },
    "exclude": [
        "node_modules"
    ],
    "include": ["./src/**/*", "../shared/*.d.ts"]
}
