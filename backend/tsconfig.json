{
    "compilerOptions": {
        "target": "ES2020",
        "typeRoots": [
            "node"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": ".",
        "outDir": "../dist/backend",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ]
}