{
    "compilerOptions": {
        "target": "ES2020",
        "typeRoots": [
            "node"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": ".",
        "outDir": "../dist/backend",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "paths": {
            "@/types": [
                "../shared/types.d.ts"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../shared/*.d.ts"
    ]
}